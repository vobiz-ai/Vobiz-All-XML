# ── Phone numbers ─────────────────────────────────────────────────────────────
FROM_NUMBER=+91XXXXXXXXXX        # Your Vobiz DID (outbound caller ID)
AGENT_NUMBER=+91XXXXXXXXXX       # Agent's phone number (round-robin if multiple registered via API)

# ── Queue settings ────────────────────────────────────────────────────────────
MAX_WAIT_CYCLES=3                # Max hold attempts before offering voicemail
HOLD_WAIT_SECS=20                # Seconds of hold music per cycle
HOLD_MUSIC_URL=                  # URL to MP3/OGG hold music — leave blank for default beep

# ── Server ────────────────────────────────────────────────────────────────────
HTTP_PORT=8000
PUBLIC_URL=                      # Leave empty for ngrok (local dev)
NGROK_AUTH_TOKEN=                # Optional
