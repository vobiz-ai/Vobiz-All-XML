# ── Vobiz credentials ─────────────────────────────────────────────────────────
VOBIZ_AUTH_ID=your_vobiz_auth_id
VOBIZ_AUTH_TOKEN=your_vobiz_auth_token

# ── Phone numbers ─────────────────────────────────────────────────────────────
FROM_NUMBER=+91XXXXXXXXXX        # Your Vobiz DID (used as outbound caller ID)

# ── Appointment defaults (used when query params are not passed) ───────────────
APPT_NAME=there
APPT_DATE=tomorrow
APPT_TIME=10 AM

# ── Server ────────────────────────────────────────────────────────────────────
HTTP_PORT=8000
PUBLIC_URL=                      # Leave empty for ngrok (local dev)
NGROK_AUTH_TOKEN=                # Optional
