# ── Vobiz credentials ─────────────────────────────────────────────────────────
VOBIZ_AUTH_ID=MA_XXXXXXXXXXXXXXXXXXXXXXXXXX   # Your Vobiz account auth ID
VOBIZ_AUTH_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXX     # Your Vobiz account auth token

# ── Phone numbers ─────────────────────────────────────────────────────────────
FROM_NUMBER=+91XXXXXXXXXX                     # Your Vobiz DID (caller ID for outbound)

# ── Conference settings ───────────────────────────────────────────────────────
CONFERENCE_NAME=BackgroundAudioRoom           # Name of the conference room

# ── Background audio ──────────────────────────────────────────────────────────
# URL to the audio file played continuously in the background (MP3 or WAV).
# Must be publicly accessible over HTTPS.
BACKGROUND_AUDIO_URL=https://example.com/your-background-music.mp3

# How many seconds to wait before re-triggering the audio file (loop interval).
# Set this to approximately the duration of your audio file in seconds.
# Example: for a 60-second music loop, set to 58 (slight overlap avoids silence).
AUDIO_LOOP_INTERVAL_SECS=30

# ── Server ────────────────────────────────────────────────────────────────────
HTTP_PORT=8000
PUBLIC_URL=                                   # Set for EC2/production — skips ngrok
NGROK_AUTH_TOKEN=                             # Optional ngrok auth token for local dev
