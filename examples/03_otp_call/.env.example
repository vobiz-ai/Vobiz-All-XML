# ── Vobiz credentials ─────────────────────────────────────────────────────────
VOBIZ_AUTH_ID=your_vobiz_auth_id
VOBIZ_AUTH_TOKEN=your_vobiz_auth_token

# ── Phone numbers ─────────────────────────────────────────────────────────────
FROM_NUMBER=+91XXXXXXXXXX        # Your Vobiz DID (caller ID for outbound OTP calls)

# ── OTP settings ──────────────────────────────────────────────────────────────
# OTP_CODE is only used as a fallback for testing — real OTPs are generated by /send-otp
OTP_CODE=123456

# ── Server ────────────────────────────────────────────────────────────────────
HTTP_PORT=8000
PUBLIC_URL=                      # Leave empty for ngrok (local dev)
NGROK_AUTH_TOKEN=                # Optional
