# ── Vobiz credentials ─────────────────────────────────────────────────────────
VOBIZ_AUTH_ID=your_vobiz_auth_id
VOBIZ_AUTH_TOKEN=your_vobiz_auth_token

# ── Phone numbers ─────────────────────────────────────────────────────────────
FROM_NUMBER=+91XXXXXXXXXX        # Your Vobiz DID (caller ID for transfers)

# ── Department transfer numbers (update via PUT /config/department/{dept}) ────
# These are the initial defaults — change them at runtime via the API
# Dept IDs: sales | support | billing | operator

# ── Server ────────────────────────────────────────────────────────────────────
HTTP_PORT=8000
PUBLIC_URL=                      # Leave empty for ngrok (local dev)
                                 # Set to http://your-ip:8000 for production (EC2 etc.)
NGROK_AUTH_TOKEN=                # Optional — reads from system ngrok config if blank
