# Deepgram
DEEPGRAM_API_KEY=your_deepgram_api_key

# OpenAI (used for both LLM and TTS)
OPENAI_API_KEY=your_openai_api_key

# Vobiz
VOBIZ_AUTH_ID=your_auth_id
VOBIZ_AUTH_TOKEN=your_auth_token

# Call settings
FROM_NUMBER=+91XXXXXXXXXX
TO_NUMBER=+91XXXXXXXXXX

# Agent personality
AGENT_SYSTEM_PROMPT=You are a helpful AI phone assistant. Be concise and conversational. Keep responses under 2 sentences.

# OpenAI TTS voice: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE=alloy

# Server mode: "stream" (AI agent, default) or "test" (XML test pipeline IVR)
SERVER_MODE=stream

# --- Production (Render / AWS) ---
# On Render: leave blank — RENDER_EXTERNAL_URL is set automatically.
# On AWS/other: set to your public HTTPS URL, e.g.:
#   PUBLIC_URL=https://vobiz-voice-agent.onrender.com
#   PUBLIC_URL=https://ec2-13-233-xx-xx.ap-south-1.compute.amazonaws.com
PUBLIC_URL=

# --- Local Dev (ngrok) ---
# Leave PUBLIC_URL empty for local dev — ngrok is used automatically.
NGROK_AUTH_TOKEN=

# --- XML Test Pipeline ---
DIAL_TEST_NUMBER=+91XXXXXXXXXX
TEST_AUDIO_URL=https://actions.google.com/sounds/v1/alarms/beep_short.ogg

# --- Ports ---
# On Render, PORT is injected automatically — no need to set HTTP_PORT.
HTTP_PORT=8000
AGENT_WS_PORT=8001
